AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MAIL_EMAIL=
MAIL_PASSWORD=
ANTHROPIC_API_KEY=
SECRET_KEY=
# For local DynamoDB (docker-compose): DYNAMODB_ENDPOINT_URL=http://localhost:8000
